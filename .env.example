DATABASE_URL=postgresql://zenvort:zenvort@postgres:5432/zenvort
REDIS_URL=redis://redis:6379

# Frontend URL — restrict CORS to this origin
# In development: http://localhost:5173
# In production: https://app.zenvort.io
ALLOWED_ORIGIN=http://localhost:5173

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

PORT=3000

RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

WORKER_CONCURRENCY=3

# ── Worker internals (no need to change defaults) ────────────────────────────
# Metrics server port (internal only)
# WORKER_METRICS_PORT=3001
# Orphan cleanup interval in ms (default: 10 min)
# WORKER_CLEANUP_INTERVAL_MS=600000
# Orphan file max age in ms (default: 30 min)
# WORKER_ORPHAN_MAX_AGE_MS=1800000
