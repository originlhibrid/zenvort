{
  "name": "@zenvort/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "node dist/index.js",
    "start": "node dist/index.js",
    "build": "tsc",
    "clean": "rm -rf dist",
    "clear-stale": "node --import tsx src/scripts/clearStaleJobs.ts",
    "test-routes": "node --import tsx src/scripts/testAllRoutes.ts",
    "test-routes:docker": "docker exec zenvort-worker node --import tsx src/scripts/testAllRoutes.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@zenvort/db": "workspace:*",
    "@zenvort/queue": "workspace:*",
    "@zenvort/storage": "workspace:*",
    "async-mutex": "^0.5.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node-cron": "^3.0.0",
    "@types/tmp": "^0.2.6"
  }
}